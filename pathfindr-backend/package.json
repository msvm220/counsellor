{
  "name": "pathfindr-backend",
  "version": "1.0.0",
  "description": "PathFindr Career Counseling Platform - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:prod": "NODE_ENV=production node src/server.js",
    "start:pm2": "pm2 start ecosystem.config.js --env production",
    "dev": "node --watch src/server.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src/",
    "db:migrate": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "docker:build": "docker build -t pathfindr-backend .",
    "health": "curl -s http://localhost:5000/healthz | node -e \"process.stdin.resume(); process.stdin.on('data', d => { const r = JSON.parse(d); console.log(r.status === 'ok' ? 'Healthy' : 'Unhealthy'); });\""
  },
  "keywords": [
    "career",
    "counseling",
    "pathfindr"
  ],
  "author": "PathFindr Team",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1037.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "cors-gate": "^1.1.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.3",
    "msg91": "^2.2.8",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.6",
    "openai": "^6.34.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "razorpay": "^2.9.6",
    "socket.io": "^4.8.3",
    "winston": "^3.19.0",
    "xss-clean": "^0.1.4",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  }
}
